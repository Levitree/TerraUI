{
  "name": "@terranovasystems/terraui",
  "version": "0.2.0",
  "description": "Terranova design-system components, composables, and tokens. Framework: Vue 3, Tailwind v4, Lucide icons.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables/index.js"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "import": "./dist/stores/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./styles": "./dist/styles/terraui.css",
    "./styles/tokens": "./dist/styles/tokens/colors.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm clean && pnpm build:js && pnpm build:css && pnpm build:types",
    "build:js": "vite build",
    "build:css": "tailwindcss -i src/styles/index.css -o dist/styles/terraui.css --minify && mkdir -p dist/styles/tokens && cp src/styles/tokens/colors.css dist/styles/tokens/colors.css",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "dev": "pnpm build:css && concurrently -n js,css,types -c blue,magenta,cyan \"vite build --watch\" \"tailwindcss -i src/styles/index.css -o dist/styles/terraui.css --watch\" \"vue-tsc -p tsconfig.build.json --watch --preserveWatchOutput\"",
    "clean": "rm -rf dist",
    "typecheck": "vue-tsc -p tsconfig.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@tanstack/vue-table": "^8.21.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^5.0.0",
    "zod": "^4.0.0"
  },
  "dependencies": {
    "lucide-vue-next": "^0.545.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.2.2",
    "@tanstack/vue-table": "^8.21.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "pinia": "^3.0.4",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-tsc": "^3.2.6",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@11.0.0-dev.1005+sha512.91f84a392eea348ea4852a182912d2520273a4336f933b78cc44bc931eb999923c097e9433a9b355adc1f725725ea99082fc9f032a559df832632e764c92c798",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
