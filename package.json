{
  "name": "@terranovasystems/terraui",
  "version": "0.8.4",
  "description": "Terranova design-system components, composables, and tokens. Framework: Vue 3, Tailwind v4, Lucide icons.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Levitree/TerraUI.git"
  },
  "homepage": "https://github.com/Levitree/TerraUI#readme",
  "bugs": {
    "url": "https://github.com/Levitree/TerraUI/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./styles": "./src/styles/index.css",
    "./styles/tokens": "./src/styles/tokens/colors.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm clean && pnpm build:js && pnpm build:types && pnpm build:llms",
    "build:js": "vite build",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "build:llms": "tsx scripts/build-llm-docs.ts",
    "dev": "concurrently -n js,types -c blue,cyan \"vite build --watch\" \"vue-tsc -p tsconfig.build.json --watch --preserveWatchOutput\"",
    "clean": "rm -rf dist",
    "typecheck": "vue-tsc -p tsconfig.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "story:dev": "histoire dev",
    "story:build": "histoire build",
    "story:preview": "histoire preview",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@tanstack/vue-table": "^8.21.0",
    "vue": "^3.5.0",
    "vue-router": "^5.0.0",
    "zod": "^4.0.0"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@histoire/plugin-vue": "1.0.0-beta.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-table": "^8.21.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "histoire": "1.0.0-beta.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vue": "^3.5.32",
    "vue-component-meta": "^3.2.6",
    "vue-router": "^5.0.4",
    "vue-tsc": "^3.2.6",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@11.0.0-rc.2+sha512.26410cc26d668baddde13a0acf2c75cad00b82a477bcc1e2fe629dd41d6b78fe3fb2d9bb523afff79d6a91f06be9b90a6032543f30b5f73931239c820aa5f001",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}